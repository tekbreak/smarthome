# =============================================================================
# Smart Home - Environment Variables (project root)
# Copy to .env and fill in your values. All subfolders use this single file.
# =============================================================================

# --- Tuya IoT (shared by server and smart-home) ---
# Get credentials from https://iot.tuya.com/
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_HOST=https://openapi.tuyaeu.com
TUYA_TEST_DEVICE=

# --- Weather API (server) ---
# https://www.weatherapi.com/ - optional; uses cache if missing
WEATHER_API_KEY=

# --- WebSocket URLs ---
# Client (Vite): must use VITE_ prefix for client-side exposure
# Use ws:// for local dev, wss:// for production
VITE_WEBSOCKET_URL=ws://localhost:8001

# Smart-home door sensor: WebSocket dashboard URL (wss:// or ws://)
WSS_URL=ws://localhost:8001

# --- Server (WebSocket backend) ---
PORT=8001
SSL_CERT_PATH=server.pem
SSL_KEY_PATH=server.key
# Set to 1 for local dev without SSL (uses HTTP/ws://)
# WS_INSECURE=1

# --- Android app (HTTP Basic Auth for dashboard) ---
# Used when https://home-dashboard.tekbreak.com/ requires auth
AUTH_USERNAME=
AUTH_PASSWORD=

# --- Optional debug flags ---
# DEVICE_STATUS_DEBUG=1  # Log Tuya sensor status codes to logs/device-status-debug.log
# DEBUG=1                # Smart-home debug mode (smart-home/old)
